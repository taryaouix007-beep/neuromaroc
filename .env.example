# =========================================================================
# INFC - NEUROMAROC WEB APPLICATION ENVIRONMENT CONFIGURATION
# =========================================================================
# Copy this file to `.env.local` for local development.
# Do NOT commit `.env.local` to git version control.
# =========================================================================

# -------------------------------------------------------------------------
# 1. Application Status & URLs
# -------------------------------------------------------------------------

# Website Access Control Status:
# - 'online': Default fully operational website mode.
# - 'construction': Redirects all public traffic to the "Coming Soon" page.
# How to get/set: Set to 'online' or 'construction'.
NEXT_PUBLIC_WEBSITE_STATUS=online

# Public Application Canonical URL:
# - Used for absolute URL generation in SEO meta tags, sitemaps, RSS feeds, and redirects.
# How to get/set: 
#   - Local development: http://localhost:3000 (or http://localhost:3001)
#   - Production: https://neuromaroc.com
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -------------------------------------------------------------------------
# 2. Local/Cloud Supabase Database Integration
# -------------------------------------------------------------------------
# The database handles contact forms, newsletter signups, blog posts, and forum data.

# Supabase API Endpoint URL:
# How to get/set:
#   - Local development: http://127.0.0.1:54321 (Default port after running `supabase start`)
#   - Production: Project URL from the Supabase Dashboard (Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabase Anonymous/Public API Key:
# - Safe to expose to the client-side browser.
# How to get/set:
#   - Local development: Run `supabase status` in the terminal and copy the "Publishable" key.
#   - Production: Project Settings -> API -> `anon` public key in the Supabase Dashboard.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# Supabase Service Role Key:
# - Server-side only. NEVER expose to the client-side or use prefix `NEXT_PUBLIC_`.
# - Used for administrative functions, database seeding, and bypassing Row Level Security (RLS).
# How to get/set:
#   - Local development: Run `supabase status` in the terminal and copy the "Secret" key.
#   - Production: Project Settings -> API -> `service_role` secret key in the Supabase Dashboard.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key_here


# -------------------------------------------------------------------------
# 3. XpRia Core Cabinet API Integration
# -------------------------------------------------------------------------
# The XpRia system manages physical franchise cabinets, booking scheduling, and the patient portal.

# XpRia Core API Gateway URL:
# How to get/set:
#   - Local development: http://localhost:3000 (Points to the local running XpRia cabinet backend instance)
#   - Production: The API domain of the deployed XpRia backend.
NEXT_PUBLIC_XPRIA_API_URL=http://localhost:3000

# XpRia API Authentication Key (Client-side):
# - Publicly accessible client key used directly in patient portal pages.
# How to get/set: Retrieve the cabinet-specific token from the XpRia backend config or admin.
NEXT_PUBLIC_XPRIA_API_KEY=xpk_your_xpria_public_api_key_here

# XpRia API Authentication Key (Server-side):
# - Private server-side key for secure proxy requests (without `NEXT_PUBLIC_` prefix).
# How to get/set: Retrieve from the XpRia backend config or admin.
XPRIA_API_KEY=xpk_your_xpria_private_api_key_here
